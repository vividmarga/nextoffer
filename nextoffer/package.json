{
  "name": "nextoffer",
  "version": "0.1.0",
  "private": true,
  "description": "NextOffer UK — Premium affiliate comparison platform",
  "scripts": {
    "dev":        "next dev --turbopack",
    "build":      "next build",
    "build:cf":   "npx @cloudflare/next-on-pages",
    "preview:cf": "npm run build:cf && npx wrangler pages dev .vercel/output/static",
    "start":      "next start",
    "lint":       "next lint",
    "type-check": "tsc --noEmit",
    "format":     "prettier --write .",
    "db:push":    "supabase db push",
    "db:types":   "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > src/types/supabase.ts",
    "deploy:cf":  "npm run build:cf && wrangler pages deploy .vercel/output/static --project-name=nextoffer"
  },
  "dependencies": {
    "next":                    "15.3.2",
    "react":                   "19.1.0",
    "react-dom":               "19.1.0",
    "@supabase/supabase-js":   "^2.45.0",
    "framer-motion":           "^12.0.0",
    "lucide-react":            "^0.475.0",
    "class-variance-authority":"^0.7.1",
    "clsx":                    "^2.1.1",
    "tailwind-merge":          "^2.5.0",
    "@radix-ui/react-accordion":      "^1.2.1",
    "@radix-ui/react-dialog":         "^1.1.2",
    "@radix-ui/react-dropdown-menu":  "^2.1.2",
    "@radix-ui/react-navigation-menu":"^1.2.1",
    "@radix-ui/react-select":         "^2.1.2",
    "@radix-ui/react-slider":         "^1.2.1",
    "@radix-ui/react-switch":         "^1.1.1",
    "@radix-ui/react-tabs":           "^1.1.1",
    "@radix-ui/react-toast":          "^1.2.2",
    "@radix-ui/react-tooltip":        "^1.1.4",
    "next-mdx-remote":         "^5.0.0",
    "gray-matter":             "^4.0.3",
    "reading-time":            "^1.5.0",
    "resend":                  "^4.0.0",
    "sharp":                   "^0.33.5",
    "zod":                     "^3.23.8"
  },
  "devDependencies": {
    "@types/node":                    "^22.0.0",
    "@types/react":                   "^19.0.0",
    "@types/react-dom":               "^19.0.0",
    "typescript":                     "^5.7.0",
    "tailwindcss":                    "^3.4.17",
    "postcss":                        "^8.4.49",
    "autoprefixer":                   "^10.4.20",
    "@tailwindcss/typography":        "^0.5.15",
    "@tailwindcss/forms":             "^0.5.9",
    "eslint":                         "^9.0.0",
    "eslint-config-next":             "15.3.2",
    "prettier":                       "^3.3.3",
    "prettier-plugin-tailwindcss":    "^0.6.9",
    "supabase":                       "^1.210.0",
    "@cloudflare/next-on-pages":      "^1.13.12",
    "wrangler":                       "^3.99.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
